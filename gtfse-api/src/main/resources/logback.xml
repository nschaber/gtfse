<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>
                %cyan([%date{"yyyy-MM-dd'T'HH:mm:ssXXX", UTC}])-%highlight([%-6p])-%blue([%-15.-15c{0}])-%cyan([%-10.-10t{0}]) -- %msg%n
            </pattern>
        </encoder>
    </appender>
    <root level="info">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
